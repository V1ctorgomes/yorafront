# =============================================================================
# EasyPanel — variáveis para deploy via Dockerfile (yorafront)
# Configure no painel; não é necessário commitar .env no repositório.
# =============================================================================

# --- BUILD (aba Build / Build Arguments — exige redeploy ao alterar) ---
# Use o domínio do FRONTEND (loja):
NEXT_PUBLIC_SITE_URL=https://yora-frontend.pknzmz.easypanel.host
# Use o domínio do BACKEND (API) — sem barra no final, sem https duplicado:
NEXT_PUBLIC_API_URL=https://yora-backend.pknzmz.easypanel.host

# --- RUNTIME (aba Environment) ---
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
